    HOTEL_NAME,
    UPPER(ROOM_TYPE) AS ROOM_TYPE,
    ROOM_NO,
    TO_NUMBER(REPLACE(BASE_PRICE, ',', '')) AS BASE_PRICE,
    CURRENT_TIMESTAMP() AS CREATED_AT
FROM hoteldb_prd.bronze.room_raw
        );
