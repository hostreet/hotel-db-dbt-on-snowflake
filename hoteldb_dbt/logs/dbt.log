    GUEST_ID,
    TRIM(GUEST_NAME) AS GUEST_NAME,
    PHONE,
    LOWER(EMAIL) AS EMAIL,
    UPPER(COUNTRY) AS COUNTRY_CODE,
    CURRENT_TIMESTAMP() AS CREATED_AT
FROM hoteldb_prd.bronze.guest_raw
        );
