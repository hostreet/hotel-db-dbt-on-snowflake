    UPPER(STATUS) AS STATUS,
    IFF(UPPER(STATUS) = 'CANCELLED', TRUE, FALSE) AS IS_CANCELLED,
    CURRENT_TIMESTAMP() AS CREATED_AT
FROM hoteldb_prd.bronze.reservation_raw
        );
