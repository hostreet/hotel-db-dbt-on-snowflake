        copy grants as
        (-- Silver layer: room 테이블 정제 모델
-- Co-authored with CoCo
SELECT
    ROOM_ID,
    HOTEL_NAME,
    UPPER(ROOM_TYPE) AS ROOM_TYPE,
    ROOM_NO,
