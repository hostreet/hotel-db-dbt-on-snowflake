SELECT
    RESERVATION_ID,
    GUEST_ID,
    ROOM_ID,
    TO_DATE(REPLACE(CHECK_IN_DATE, '/', '-')) AS CHECK_IN_DATE,
    TO_DATE(REPLACE(CHECK_OUT_DATE, '/', '-')) AS CHECK_OUT_DATE,
